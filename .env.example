# Copy to .env on VPS (never commit .env)
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-3.1-flash-lite

# =============================================================================
# A+B+C+D+E production (LSFC + DBBS + DiNapoli + VAMR + SMRS Model A)
# Manifest v12: Live Phase2 + DBBS SL-first/-1R + Fintokei 3% lot cap
# =============================================================================

# --- Shared defenses (all strategies) ---
PROFIT_CUSHION_ENABLED=1
PROFIT_CUSHION_TARGET_PCT=2.0
PROFIT_CUSHION_LOT_MULT=0.65
TWIN_BRAKE_ENABLED=1
DD_THROTTLING_ENABLED=1

# --- L2: one open position per strategy per symbol (A/B/C/D/E) ---
# Pyramiding-enabled strategies auto-disable L2 for that strategy only (default: LSFC).
MUTUAL_EXCLUSION_ENABLED=1
PYRAMID_ENABLED=1
PYRAMID_LSFC=1
# Live bridge pyramid + trailing SL (defaults ON when PYRAMID_ENABLED=1; set 0 to disable)
LIVE_PYRAMID_ENABLED=1

# --- Fintokei commission (SL / trailing floor) ---
# One-way USD 3 / 1.0 lot → round-trip USD 6 / 1.0 lot
FINTOKEI_COMMISSION_ONE_WAY_USD=3
FINTOKEI_MIN_NET_PROFIT_USD=0.50
# Disqualify if one closed position loses >= 3% of equity (BT sim + Live lot cap)
FINTOKEI_SINGLE_POSITION_RULE_ENABLED=1
FINTOKEI_SINGLE_POSITION_LOSS_LIMIT_PCT=3.0

# --- Live forward TP cap (MT5 only — backtest unchanged) ---
LIVE_TP_CAP_ENABLED=1
LIVE_TP_MAX_R=1.5

# --- Live phase 2: pyramid BE after TP / DBBS H1 trail ---
LIVE_PYRAMID_BE_AFTER_TP=1
LIVE_PYRAMID_BE_TP_BUFFER_R=0.05
DBBS_LIVE_TRAIL_ENABLED=1

# --- Portfolio Equity Trail (PET) — Phase 5.2 account-level profit protection ---
# Default: OFF in challenge, ON after funded pass (see configs/pet_config.json profile_defaults)
# Override either profile: PET_ENABLED=1|0
# PET_MODE=SOFT
# PET_MODE=MEDIUM
# PET_MODE=HARD
# PET_CONFIG_PATH=configs/pet_config.json

# --- Bridge UI (VPS: JSON API only — no HTML dashboard) ---
BRIDGE_MOUNT_DASHBOARD=0
# Local machine only (start_local_dashboard.bat):
# VPS_BRIDGE_URL=http://127.0.0.1:8000
# LOCAL_DASHBOARD_PORT=8080
# SSH tunnel: ssh -L 8000:127.0.0.1:8000 user@your-vps

# --- Portfolio allocation (production default OFF — full lot) ---
PORTFOLIO_ALLOCATION_ENABLED=0
# PORTFOLIO_ALLOCATION_ENABLED=1
# PORTFOLIO_STRATEGY_WEIGHTS_FILE=deploy/portfolio_allocation_weights.json

# --- Strategy A — LSFC ---
# (no extra env vars — defaults ON)

# --- Strategy B — DBBS (EURUSD, GBPUSD, XAUUSD) ---
DBBS_DEFENSE=1
DBBS_PURE_DATA_MODE=0
DBBS_BEAR_KILL_SWITCH=1
DBBS_BEAR_KILL_SWITCH_THRESHOLD=0.20
DBBS_L2_MIN_SCORE=0

# --- Strategy C — DiNapoli ---
DINAPOLI_DEFENSE=1
DN_PROP_GATE=1
CHALLENGE_BASE_RISK_PCT_MAX=0.006
DN_PROP_GATE_BASE_RISK_PCT=0.006

# --- Strategy D — Volume Area Mean Reversion to POC (略称 VAMR, AUDNZD/EURGBP/USDCAD) ---
VAMR_DEFENSE=1
VAMR_GEMINI_AUDIT=0

# --- Strategy E — Statistical Mean Reversion Scalper (略称 SMRS, Model A) ---
# Defaults: strategies/smrs_production.py (PRODUCTION_SPEC)
# Bayes ON | Gemini OFF | Pyramiding OFF | L0–L2 + L4.5 + 3 brakes ON
SMRS_DEFENSE=1
SMRS_GEMINI_AUDIT=0
SMRS_LLM_AUDIT=0
SMRS_L2_MIN_SCORE=0
PYRAMID_SMRS=0
# Sizing: p<0.70 SKIP | 0.70–0.80 0.50R | 0.80–0.90 1.00R | p≥0.90 1.50R
# Bayes artifact: backtest_results/models/smrs_bayes_v1.json (manifest v12)
# M1 bars on AUDNZD/EURGBP/NZDUSD charts (PropEA_Bridge auto-selects PERIOD_M1)
# AUDNZD/EURGBP overlap with VAMR — per-strategy L2 applies by setup_type (SMRS vs VAMR)

# --- Optional ---
# PROP_FIRM_PROFILE=challenge
# PROP_FIRM_PROFILE=funded
# DINAPOLI_PURE_BT=0
# LLM_AUDIT_ENABLED=0
