# Copy to .env on VPS (never commit .env)
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-3.1-flash-lite

# A+B+C+D production (LSFC + DBBS + DiNapoli + VAMR) — recommended on VPS
DINAPOLI_DEFENSE=1
DN_PROP_GATE=1
CHALLENGE_BASE_RISK_PCT_MAX=0.006
DN_PROP_GATE_BASE_RISK_PCT=0.006

# Strategy B — Dual Bollinger Band Squeeze / DBBS (EURUSD, GBPUSD, XAUUSD)
DBBS_DEFENSE=1
DBBS_PURE_DATA_MODE=0
DBBS_BEAR_KILL_SWITCH=1
DBBS_BEAR_KILL_SWITCH_THRESHOLD=0.20
DBBS_L2_MIN_SCORE=0

# Strategy D — Volume Area Mean Reversion to POC (AUDNZD, EURGBP, USDCAD)
VAMR_DEFENSE=1
VAMR_GEMINI_AUDIT=0

PROFIT_CUSHION_ENABLED=1
PROFIT_CUSHION_TARGET_PCT=2.0
PROFIT_CUSHION_LOT_MULT=0.65
TWIN_BRAKE_ENABLED=1
DD_THROTTLING_ENABLED=1

# L2: one open position per strategy per symbol (A/B/C/D each max 1 per symbol)
# Pyramiding-enabled strategies auto-disable L2 for that strategy only (default: LSFC).
MUTUAL_EXCLUSION_ENABLED=1
PYRAMID_ENABLED=1
PYRAMID_LSFC=1

# Portfolio strategy allocation (optional — production default OFF)
PORTFOLIO_ALLOCATION_ENABLED=0
# To enable post-hoc optimized weights (see portfolio_allocation_optimizer.py):
# PORTFOLIO_ALLOCATION_ENABLED=1
# PORTFOLIO_STRATEGY_WEIGHTS_FILE=deploy/portfolio_allocation_weights.json
# PORTFOLIO_STRATEGY_WEIGHTS={"LONDON_SWEEP_FAILURE_CONTINUATION":0.441,"DBBS":0.238,"DINAPOLI_STRUCTURE":0.271,"VAMR":0.05}
# Remove legacy daily/concurrent — ignored if set:
# MUTUAL_EXCLUSION_MODE=daily

# Optional
# PROP_FIRM_PROFILE=challenge
# DINAPOLI_PURE_BT=0
# MUTUAL_EXCLUSION_ENABLED=0
#
# PROFIT_CUSHION_LOT_MULT=0.65 applies to all strategies (abc / abcd / single-strategy BT).
# It is not tied to Strategy D (VAMR).
